<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--    BOTAO DE VOLTAR-->
    <style name="button_back">
        <item name="android:layout_marginStart">20dp</item>
        <item name="android:layout_marginTop">20dp</item>
    </style>

<!--    SUBTITULO DO HEADER-->
    <style name="workout_header_subtitle">
        <item name="android:layout_marginStart">20dp</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:textColor">@color/main_background</item>
        <item name="android:textSize">17sp</item>
    </style>
    
        <!--        LABEL DE SERIES CONCLUIDAS-->
    <style name="label_completed_series">
        <item name="android:layout_marginStart">20dp</item>
        <item name="android:layout_marginTop">20dp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!--        CHECKBOX DE SERIES CONCLUIDAS-->
    <style name="checkbox_completed_series">
        <item name="android:background">@color/bg_card</item>
        <item name="android:layout_marginTop">16dp</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_marginEnd">16dp</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

<!--    CHIP DO CHECKBOX DE SERIE (SE FEITO)-->
    <style name="workout_card_done_status">
        <item name="android:text">Feito</item>
        <item name="android:background">@color/teal_light</item>
        <item name="android:textColor">@color/teal_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:paddingTop">3dp</item>
        <item name="android:paddingBottom">3dp</item>
        <item name="android:textSize">10dp</item>
    </style>

<!--    CHIP DO CHECKBOX DE SERIE (SE PENDENTE)-->
    <style name="workout_card_pending_status">
        <item name="android:text">Pendent</item>
        <item name="android:background">@color/orange_pale</item>
        <item name="android:textColor">@color/coral_dark</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:paddingTop">3dp</item>
        <item name="android:paddingBottom">3dp</item>
        <item name="android:textSize">10dp</item>
    </style>

<!--        LABEL DO TEXTO DE OBSERVACOES DO TREINO-->
    <style name="label_observations">
        <item name="android:layout_marginStart">20dp</item>
        <item name="android:layout_marginTop">20dp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textStyle">bold</item>
    </style>

<!--    LINEARLAYOUT DE OBSERVACOES DO TREINO-->
    <style name="linear_layout_text_observations">
        <item name="android:padding">8dp</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_marginEnd">16dp</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

<!--    TEXTO DE OBSERVACOES DO TREINO-->
    <style name="text_observations">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

</resources>