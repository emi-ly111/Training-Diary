<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/main_background"
    android:id="@+id/main">

    <!--    OBS: ESSA TELA EH O MOLDE PARA A TELA DE CADA EXERCICIO DO TREINO. -->
    <!--    O NOME DO EXERCICIO, AS SERIES, REPETICOES E PESOS SAO EXEMPLOS. BOA SORTE KKKKKKKKKKKKKKKKKKKK-->

    <!--  HEADER  -->
    <RelativeLayout
        android:id="@+id/header"
        style="@style/header"
        android:layout_width="0dp"
        android:layout_height="145dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!--    LINHA DO BOTAO + TITULO-->
        <LinearLayout
            android:id="@+id/header_title_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!--    BOTAO PARA VOLTAR-->
            <ImageView
                android:id="@+id/button_back"
                style="@style/button_back"
                android:background="@drawable/ic_button_back"/>

            <!--    TITULO-->
            <TextView
                android:id="@+id/workout_header_title"
                style="@style/header_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="0dp"
                android:text="Rosca Direta"/>

        </LinearLayout>

        <!--    SUBTITULO-->
        <TextView
            android:id="@+id/date"
            style="@style/workout_header_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Biceps - 3 series de 12 repeticoes"
            android:layout_below="@+id/header_title_row"/>

    </RelativeLayout>

<!--    COMEÇO DA TELA ROLAVEL -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@+id/header"
        app:layout_constraintBottom_toTopOf="@+id/bottomNav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

<!--        IMAGEM DO CARA SARADAO-->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="350dp">

            <ImageView
                android:layout_centerHorizontal="true"
                android:id="@+id/ic_rosca_direta"
                android:layout_marginTop="16dp"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:background="@drawable/ic_rosca_direta">
            </ImageView>

<!--            LABEL DE SERIES CONCLUIDAS-->
            <TextView
                android:id="@+id/label_completed_series"
                android:layout_width="wrap_content"
                style="@style/label_completed_series"
                android:layout_height="wrap_content"
                android:text="Séries (marque as concluídas)"
                android:layout_below="@+id/ic_rosca_direta">
            </TextView>

            <!-- SERIE 1 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/serie_1"
                style="@style/checkbox_completed_series"
                android:layout_below="@+id/label_completed_series"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border_default">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="8dp">

                <androidx.appcompat.widget.AppCompatCheckBox
                    android:id="@+id/checkbox_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:buttonTint="@color/teal_primary">

                </androidx.appcompat.widget.AppCompatCheckBox>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Série 1"
                        android:textColor="@color/text_main"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10 reps · 12 kgs"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <TextView
                            style="@style/workout_card_done_status"
                            android:id="@+id/card_status_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                        </TextView>
                    </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

<!--            SERIE 2 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/serie_2"
                style="@style/checkbox_completed_series"
                android:layout_below="@+id/serie_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border_default">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="8dp">

                    <androidx.appcompat.widget.AppCompatCheckBox
                        android:id="@+id/checkbox_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:buttonTint="@color/teal_primary">

                    </androidx.appcompat.widget.AppCompatCheckBox>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Série 2"
                            android:textColor="@color/text_main"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10 reps · 12 kgs"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <TextView
                            style="@style/workout_card_done_status"
                            android:id="@+id/card_status_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                        </TextView>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

<!--            SERIE 3 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/serie_3"
                style="@style/checkbox_completed_series"
                android:layout_below="@+id/serie_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border_default">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="8dp">

                    <androidx.appcompat.widget.AppCompatCheckBox
                        android:id="@+id/checkbox_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:buttonTint="@color/teal_primary">

                    </androidx.appcompat.widget.AppCompatCheckBox>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Série 3"
                            android:textColor="@color/text_main"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10 reps · 12 kgs"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/card_status_3"
                            style="@style/workout_card_pending_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pendente">
                        </TextView>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

<!--            LABEL OBSERVACOES-->
            <TextView
                style="@style/label_observations"
                android:id="@+id/label_observations"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/serie_3"
                android:text="Observações">
            </TextView>

<!--            TEXTO DE OBSERVACOES-->
            <LinearLayout
                style="@style/linear_layout_text_observations"
                android:background="@drawable/bg_linear_layout_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/label_observations">

                <TextView
                    style="@style/text_observations"
                    android:id="@+id/text_observations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mantenha sempre as costas eretas durante a execução do exercício. Se sentir qualquer desconforto, pare imediatamente e consulte um profissional de saúde. Lembre-se de ajustar a carga conforme necessário para garantir uma execução segura e eficaz do movimento.">
                </TextView>

            </LinearLayout>

    </RelativeLayout>
</ScrollView>

<!--    MENU DE NAVEGACAO-->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>