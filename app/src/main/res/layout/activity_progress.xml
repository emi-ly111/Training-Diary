<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:id="@+id/main"
    android:layout_height="match_parent"
    android:background="@color/bg_page">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/orange_primary"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!--    BOTAO DE VOLTAR-->
        <ImageView
            android:id="@+id/button_back"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="2dp"
            style="@style/button_back"
            android:background="@drawable/ic_button_back"/>

        <!--    TITULO-->
        <TextView
            style="@style/progress_header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Progresso"/>

        <!--    SUBTITULO-->
        <TextView
            style="@style/progress_header_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Acompanhe sua evolucao"/>

        <!--    TOGGLE DE PERIODO-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_period_toggle"
            android:padding="3dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_7dias"
                style="@style/period_btn"
                android:layout_marginEnd="2dp"
                android:text="7 dias"/>

            <TextView
                android:id="@+id/btn_30dias"
                style="@style/period_btn_active"
                android:layout_marginEnd="2dp"
                android:text="30 dias"/>

            <TextView
                android:id="@+id/btn_3meses"
                style="@style/period_btn"
                android:text="3 meses"/>

        </LinearLayout>

    </LinearLayout>

    <!-- CONTEUDO SCROLLAVEL -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@+id/header"
        app:layout_constraintBottom_toTopOf="@+id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- GRID DE STATS -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:useDefaultMargins="false">

                <!--    STAT 1: TREINOS-->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="6dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/white"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/border_default">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            style="@style/stat_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="24"/>

                        <TextView
                            style="@style/stat_unit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="treinos"/>

                        <TextView
                            style="@style/stat_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Este mes"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!--    STAT 2: SEQUENCIA-->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="6dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/white"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/border_default">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                style="@style/stat_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="6"/>

                            <TextView
                                style="@style/stat_unit"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="dias"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                style="@style/stat_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sequencia atual"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🔥"
                                android:textSize="14sp"
                                android:layout_marginStart="4dp"/>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!--    STAT 3: HORAS-->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/white"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/border_default">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            style="@style/stat_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4,8"/>

                        <TextView
                            style="@style/stat_unit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="h"/>

                        <TextView
                            style="@style/stat_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total de horas"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!--    STAT 4: TAXA-->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/white"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/border_default">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            style="@style/stat_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="82%"/>

                        <TextView
                            style="@style/stat_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Taxa de conclusao"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!--    CARD GRAFICO DE BARRAS-->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border_default">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!--    TITULO DO CARD-->
                    <TextView
                        style="@style/card_section_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Treinos por semana"/>

                    <!--    BARRAS-->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:orientation="horizontal"
                        android:gravity="bottom">

                        <!--    S1-->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical"
                            android:gravity="bottom|center_horizontal">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="35dp"
                                android:background="@drawable/bg_bar_inactive"/>

                            <TextView
                                style="@style/bar_label"
                                android:text="S1"/>

                        </LinearLayout>

                        <!--    S2-->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical"
                            android:gravity="bottom|center_horizontal">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="50dp"
                                android:background="@drawable/bg_bar_inactive"/>

                            <TextView
                                style="@style/bar_label"
                                android:text="S2"/>

                        </LinearLayout>

                        <!--    S3-->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:orientation="vertical"
                            android:gravity="bottom|center_horizontal">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="28dp"
                                android:background="@drawable/bg_bar_inactive"/>

                            <TextView
                                style="@style/bar_label"
                                android:text="S3"/>

                        </LinearLayout>

                        <!--    S4 (ATIVO)-->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="bottom|center_horizontal">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="60dp"
                                android:background="@drawable/bg_bar_active"/>

                            <TextView
                                style="@style/bar_label"
                                android:text="S4"/>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!--    CARD GRUPOS MUSCULARES-->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border_default">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!--    TITULO DO CARD-->
                    <TextView
                        style="@style/card_section_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Grupos musculares trabalhados"/>

                    <!--    PEITO 80%-->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="10dp">

                        <TextView
                            style="@style/muscle_label"
                            android:text="Peito"/>

                        <FrameLayout
                            android:layout_width="0dp"
                            android:layout_height="6dp"
                            android:layout_weight="1"
                            android:clipChildren="true">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="6dp"
                                android:layout_gravity="start"
                                android:scaleX="0.80"
                                android:transformPivotX="0dp"
                                android:background="@color/orange_primary"/>

                        </FrameLayout>

                        <TextView
                            style="@style/muscle_pct"
                            android:text="80%"/>

                    </LinearLayout>

                    <!--    PERNAS 65%-->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="10dp">

                        <TextView
                            style="@style/muscle_label"
                            android:text="Pernas"/>

                        <FrameLayout
                            android:layout_width="0dp"
                            android:layout_height="6dp"
                            android:layout_weight="1"
                            android:clipChildren="true">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="6dp"
                                android:layout_gravity="start"
                                android:scaleX="0.65"
                                android:transformPivotX="0dp"
                                android:background="@color/orange_mid"/>

                        </FrameLayout>

                        <TextView
                            style="@style/muscle_pct"
                            android:text="65%"/>

                    </LinearLayout>

                    <!--    BICEPS 50%-->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="10dp">

                        <TextView
                            style="@style/muscle_label"
                            android:text="Biceps"/>

                        <FrameLayout
                            android:layout_width="0dp"
                            android:layout_height="6dp"
                            android:layout_weight="1"
                            android:clipChildren="true">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="6dp"
                                android:layout_gravity="start"
                                android:scaleX="0.50"
                                android:transformPivotX="0dp"
                                android:background="@color/amber"/>

                        </FrameLayout>

                        <TextView
                            style="@style/muscle_pct"
                            android:text="50%"/>

                    </LinearLayout>

                    <!--    COSTAS 40%-->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="10dp">

                        <TextView
                            style="@style/muscle_label"
                            android:text="Costas"/>

                        <FrameLayout
                            android:layout_width="0dp"
                            android:layout_height="6dp"
                            android:layout_weight="1"
                            android:clipChildren="true">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="6dp"
                                android:layout_gravity="start"
                                android:scaleX="0.40"
                                android:transformPivotX="0dp"
                                android:background="@color/amber_light"/>

                        </FrameLayout>

                        <TextView
                            style="@style/muscle_pct"
                            android:text="40%"/>

                    </LinearLayout>

                    <!--    OMBROS 25%-->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="10dp">

                        <TextView
                            style="@style/muscle_label"
                            android:text="Ombros"/>

                        <FrameLayout
                            android:layout_width="0dp"
                            android:layout_height="6dp"
                            android:layout_weight="1"
                            android:clipChildren="true">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="6dp"
                                android:layout_gravity="start"
                                android:scaleX="0.25"
                                android:transformPivotX="0dp"
                                android:background="@color/amber_pale"/>

                        </FrameLayout>

                        <TextView
                            style="@style/muscle_pct"
                            android:text="25%"/>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <!--    MENU DE NAVEGACAO-->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>